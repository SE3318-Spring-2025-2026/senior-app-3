# Server Configuration
PORT=5002
NODE_ENV=development

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/senior-app
DB_HOST=localhost
DB_PORT=27017
DB_NAME=senior-app

# Encryption at Rest (AES-256-GCM)
# 32-byte (256-bit) hex key. Generate with: openssl rand -hex 32
# In production load this from Vault / Secrets Manager and inject as env var.
ENCRYPTION_KEY=replace_with_64_hex_characters

# JWT Configuration — both values are REQUIRED. Generate with: openssl rand -hex 64
JWT_SECRET=replace_with_strong_random_secret
JWT_REFRESH_SECRET=replace_with_different_strong_random_secret
JWT_EXPIRATION=1h
JWT_REFRESH_EXPIRATION=7d

# GitHub OAuth Configuration
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_REDIRECT_URI=http://localhost:5002/api/v1/auth/github/oauth/callback

# System/M2M service token for cron jobs and internal services — REQUIRED when using system auth
# Generate with: openssl rand -hex 32
SYSTEM_SERVICE_TOKEN=replace_with_strong_random_token

# Frontend Configuration
FRONTEND_URL=http://localhost:3000

# Local/demo only: set to true to allow new student signup with any email + a new
# student ID without a pre-uploaded CSV (creates/updates StudentIdRegistry).
# Must stay false in production. Requires NODE_ENV !== production.
# DEMO_OPEN_STUDENT_ONBOARDING=false

# Email Configuration
# In development: emails are logged to console only — no setup needed.
# In production, choose ONE of the two options below:

# Option A — Named service (Gmail, Outlook, Yahoo, etc.)
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password

# Option B — SMTP (Mailtrap, SendGrid SMTP, Mailgun SMTP, etc.)
# EMAIL_HOST=smtp.mailtrap.io
# EMAIL_PORT=587
# EMAIL_SECURE=false
# EMAIL_USER=your-smtp-username
# EMAIL_PASSWORD=your-smtp-password

# Password Reset Token Expiration
PASSWORD_RESET_TOKEN_EXPIRY=30m
EMAIL_VERIFICATION_TOKEN_EXPIRY=24h
