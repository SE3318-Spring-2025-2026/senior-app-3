# Server Configuration
PORT=5001
NODE_ENV=development

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/senior-app
DB_HOST=localhost
DB_PORT=27017
DB_NAME=senior-app

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production
JWT_EXPIRATION=1h
JWT_REFRESH_EXPIRATION=7d

# GitHub OAuth Configuration
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_REDIRECT_URI=http://localhost:5000/api/v1/auth/github/oauth/callback

# Frontend Configuration
FRONTEND_URL=http://localhost:3000

# Email Configuration (for verification emails)
# In development: emails are logged to console — no setup needed.
# In production: set EMAIL_USER and EMAIL_PASSWORD (Gmail or compatible SMTP).
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password

# Password Reset Token Expiration
PASSWORD_RESET_TOKEN_EXPIRY=30m
EMAIL_VERIFICATION_TOKEN_EXPIRY=24h
